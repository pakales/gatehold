# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/.pytest_cache/
/.ruff_cache/
/.mypy_cache/
/.pyright/
/.venv/
*.py[cod]
__pycache__/

# next.js
/.next/
/.vinext/
/out/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
next-env.d.ts
*.tsbuildinfo
/dist/
/.wrangler/
/outputs/
/work/

# Gatehold local state and runtime lanes
/.gatehold/
/runtime/

# Reproducible competition-media intermediates and large local exports
/media/audio/
/media/output/segments/
/media/output/segments.txt
/media/output/*.mp4
/media/review/ffprobe.json
/media/review/loudness.json
/media/review/loudness.log
