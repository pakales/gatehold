# Server-only. Never expose with a NEXT_PUBLIC_ prefix.
OPENAI_API_KEY=

# Local daemon defaults.
GATEHOLD_HOST=127.0.0.1
GATEHOLD_PORT=47820
GATEHOLD_MODEL=gpt-5.6-sol
GATEHOLD_STATE_DIR=
# Optional comma-separated exact Apple Simulator UDIDs. A pre-booted device is
# external; Gatehold shuts down only an exact device it booted and confirmed.
GATEHOLD_SIMULATORS=
# Optional comma-separated exact dashboard origins. Loopback may use HTTP;
# every non-loopback origin must use HTTPS.
GATEHOLD_DASHBOARD_ORIGINS=
