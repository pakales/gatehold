{
  "name": "gatehold",
  "version": "0.1.0",
  "description": "Local clearance control for parallel AI coding agents.",
  "private": true,
  "license": "MIT",
  "packageManager": "npm@11.10.1",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "prebuild": "node scripts/clean-build.mjs",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && node --test tests/web/*.test.mjs",
    "test:core": "uv run pytest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next",
    "check:privacy": "node scripts/check-privacy.mjs",
    "check:docs": "node scripts/check-doc-links.mjs",
    "audit:deps": "npm audit --audit-level=high && uv run --with pip-audit pip-audit",
    "core:serve": "uv run gatehold daemon",
    "core:status": "uv run gatehold status",
    "core:demo": "uv run gatehold demo",
    "smoke:model": "uv run --env-file .env.local node scripts/live-model-smoke.mjs",
    "verify": "npm run check:privacy && npm run check:docs && uv run pytest && uv run ruff check . && uv run pyright && npm run typecheck && npm run lint && npm test"
  },
  "dependencies": {
    "lucide-react": "^0.548.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.20"
    }
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.45.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.1.5",
    "wrangler": "4.112.0"
  },
  "type": "module"
}
